{
  "name": "athena.get_current_occupancy",
  "description": "Read the current occupancy count for a facility through ATHENA's public occupancy endpoint.",
  "read_only": true,
  "input": {
    "required": [
      "facility_id"
    ],
    "properties": {
      "facility_id": {
        "type": "string",
        "description": "ATHENA facility identifier."
      }
    }
  },
  "upstream": {
    "service": "athena",
    "method": "GET",
    "path": "/api/v1/presence/count",
    "query": {
      "facility": "facility_id"
    }
  }
}
